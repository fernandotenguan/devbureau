# Runtime scratch state for stateful Claude Code hooks (detect_tool_loop.py,
# check_mcp_health.py) — per-session JSON, not kit source.
.agent/.tmp/

# Third-party Claude Code skills installed locally (not part of DevBureau's own kit,
