{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "python \"$CLAUDE_PROJECT_DIR/.agent/scripts/hooks/protect_generated_files.py\""
          }
        ]
      },
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "python \"$CLAUDE_PROJECT_DIR/.agent/scripts/hooks/guard_worktree_path.py\""
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "python \"$CLAUDE_PROJECT_DIR/.agent/scripts/hooks/block_no_verify.py\""
          }
        ]
      },
      {
        "matcher": "mcp__.*",
        "hooks": [
          {
            "type": "command",
            "command": "python \"$CLAUDE_PROJECT_DIR/.agent/scripts/hooks/check_mcp_health.py\""
          }
        ]
      },
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "python \"$CLAUDE_PROJECT_DIR/.agent/scripts/hooks/enforce_design_context.py\""
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Read|WebFetch|WebSearch",
        "hooks": [
          {
            "type": "command",
            "command": "python \"$CLAUDE_PROJECT_DIR/.agent/scripts/hooks/scan_injection.py\""
          }
        ]
      },
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "python \"$CLAUDE_PROJECT_DIR/.agent/scripts/hooks/warn_debug_statements.py\""
          },
          {
            "type": "command",
            "command": "python \"$CLAUDE_PROJECT_DIR/.agent/scripts/hooks/auto_fix_on_edit.py\""
          }
        ]
      },
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "python \"$CLAUDE_PROJECT_DIR/.agent/scripts/hooks/warn_generic_design.py\""
          }
        ]
      },
      {
        "matcher": "Edit|Write|MultiEdit|Bash|Grep|Read",
        "hooks": [
          {
            "type": "command",
            "command": "python \"$CLAUDE_PROJECT_DIR/.agent/scripts/hooks/detect_tool_loop.py\""
          }
        ]
      },
      {
        "matcher": "mcp__.*",
        "hooks": [
          {
            "type": "command",
            "command": "python \"$CLAUDE_PROJECT_DIR/.agent/scripts/hooks/check_mcp_health.py\""
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "python \"$CLAUDE_PROJECT_DIR/.agent/scripts/sync_ide.py\""
          }
        ]
      }
    ]
  },
  "permissions": {
    "defaultMode": "acceptEdits",
    "allow": [
      "Bash(git status*)",
      "Bash(git diff*)",
      "Bash(git log*)",
      "Bash(git show*)",
      "Bash(git branch*)",
      "Bash(git add *)",
      "Bash(git commit *)",
      "Bash(python .agent/scripts/*)",
      "Bash(python .agent/skills/*)",
      "Bash(python -m pytest*)",
      "Bash(pytest*)",
      "Bash(npm install*)",
      "Bash(npm run *)",
      "Bash(npm test*)",
      "Bash(npx tsc*)",
      "Bash(pnpm install*)",
      "Bash(pnpm run *)",
      "Bash(yarn install*)",
      "Bash(yarn run *)",
      "Bash(mkdir *)",
      "PowerShell(git status*)",
      "PowerShell(git diff*)",
      "PowerShell(git log*)",
      "PowerShell(git show*)",
      "PowerShell(git branch*)",
      "PowerShell(git add *)",
      "PowerShell(git commit *)",
      "PowerShell(python .agent/scripts/*)",
      "PowerShell(python .agent/skills/*)",
      "PowerShell(python -m pytest*)",
      "PowerShell(npm run *)",
      "PowerShell(npm install*)"
    ],
    "ask": [
      "Bash(git push*)",
      "Bash(rm *)",
      "Bash(git reset --hard*)",
      "Bash(git clean*)",
      "PowerShell(git push*)",
      "PowerShell(Remove-Item *)",
      "PowerShell(git reset --hard*)"
    ]
  }
}
